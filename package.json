{
  "name": "hermes-quickstart",
  "productName": "Hermes Quickstart",
  "version": "0.1.0",
  "description": "Cross-platform setup wizard for Hermes Agent. Not affiliated with Nous Research.",
  "main": "electron/main.js",
  "homepage": "https://hermes-quickstart.ronnie426234.workers.dev",
  "author": {
    "name": "Cohost",
    "email": "ronnie426234@gmail.com"
  },
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder",
    "build:win": "npm run build:renderer && electron-builder --win",
    "build:mac": "npm run build:renderer && electron-builder --mac",
    "build:linux": "npm run build:renderer && electron-builder --linux",
    "start": "electron ."
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "vite": "^6.0.0",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "keytar": "^7.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "yaml": "^2.6.1"
  },
  "build": {
    "appId": "com.cohost.hermesquickstart",
    "productName": "Hermes Quickstart",
    "artifactName": "Hermes-Quickstart-${os}-${version}.${ext}",
    "files": [
      "electron/**/*",
      "src/lib/**/*",
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "artifactName": "Hermes-Quickstart-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "category": "public.app-category.developer-tools",
      "artifactName": "Hermes-Quickstart-mac-${arch}.${ext}",
      "identity": null
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] }
      ],
      "category": "Development",
      "artifactName": "Hermes-Quickstart.${ext}"
    },
    "publish": null
  }
}
